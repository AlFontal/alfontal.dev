---
import BaseLayout from '../layouts/BaseLayout.astro';
import { publications } from '../data/content';

const sortedPublications = [...publications].sort((a, b) => b.year - a.year || a.title.localeCompare(b.title));
const normalizeAuthors = (authors: string) => authors.replace(/alejandro\s+fontal/gi, 'Alejandro Fontal');
const highlightAuthors = (authors: string) => normalizeAuthors(authors).split(/(Alejandro Fontal)/g);
const publicationGroups = Object.entries(
  sortedPublications.reduce<Record<string, typeof sortedPublications>>((groups, item) => {
    const key = String(item.year);
    groups[key] ??= [];
    groups[key].push(item);
    return groups;
  }, {})
).sort((a, b) => Number(b[0]) - Number(a[0]));
---

<BaseLayout title="Publications" description="Peer-reviewed articles, conference proceedings, and thesis work.">
  <section class="page-intro page-intro--split reveal-in">
    <div class="section-head">
      <p class="section-kicker">Peer-reviewed work</p>
      <h1>Publications</h1>
      <p>Research output across epidemiology, aerobiology, microbiome work, and climate-health analysis.</p>
    </div>

    <div class="page-intro-stats" aria-label="Publication overview">
      <article>
        <span>{sortedPublications.length}</span>
        <p>listed publications</p>
      </article>
      <article>
        <span>{sortedPublications[0]?.year}</span>
        <p>latest publication year</p>
      </article>
      <article>
        <span>{sortedPublications.filter((item) => item.code).length}</span>
        <p>records with public code</p>
      </article>
    </div>
  </section>

  <section class="publication-year-grid reveal-in" aria-label="Publication records">
    {
      publicationGroups.map(([year, items]) => (
        <section class="publication-year-group">
          <div class="publication-year-label">
            <span>{year}</span>
          </div>

          <div class="publication-year-list">
            {items.map((item) => (
              <article class="publication-record">
                <header>
                  <p class="section-kicker">{item.publication}</p>
                  <h2>{item.title}</h2>
                </header>
                <p class="publication-authors">
                  {
                    highlightAuthors(item.authors).map((segment) =>
                      segment === 'Alejandro Fontal' ? <strong>{segment}</strong> : segment
                    )
                  }
                </p>
                <ul class="chip-list compact">
                  {item.categories.map((category) => <li>{category}</li>)}
                </ul>
                <div class="link-row">
                  {item.doi && (
                    <a href={item.doi} target="_blank" rel="noopener noreferrer">
                      DOI record
                    </a>
                  )}
                  {item.pdf && (
                    <a href={item.pdf} target="_blank" rel="noopener noreferrer">
                      Open PDF
                    </a>
                  )}
                  {item.code && (
                    <a href={item.code} target="_blank" rel="noopener noreferrer">
                      Code repository
                    </a>
                  )}
                </div>
              </article>
            ))}
          </div>
        </section>
      ))
    }
  </section>
</BaseLayout>
