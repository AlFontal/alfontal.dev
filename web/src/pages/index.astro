---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  educationTimeline,
  homeAnchorCards,
  homeHero,
  interestTags,
  socialLinks,
  siteMeta,
} from '../data/content';
import portraitImage from '../assets/media/alejandro_hike_profile.jpg';

const profileSocialLinks = socialLinks.filter((link) => link.label !== 'Email');
---

<BaseLayout>
  <section class="hero-grid reveal-in">
    <article class="hero-card hero-stack">
      <p class="eyebrow">Data science · bioinformatics · Barcelona</p>

      <h1>{homeHero.name}</h1>

      <p class="hero-note">{homeHero.availability}</p>
      <p class="hero-intro">{homeHero.tagline}</p>

      <div class="fact-grid" aria-label="Core focus areas">
        {
          homeHero.cards.map((card) => (
            <article class="fact-card">
              <h2>{card.title}</h2>
              <p>{card.subtitle}</p>
            </article>
          ))
        }
      </div>
    </article>

    <aside class="portrait-panel">
      <Image
        src={portraitImage}
        alt="Alejandro Fontal hiking in front of a mountain"
        width={720}
        height={720}
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
      <p class="portrait-contact">
        <a href={`mailto:${siteMeta.email}`}>{siteMeta.email}</a>
      </p>
      <ul class="portrait-socials" aria-label="Social links">
        {
          profileSocialLinks.map((link) => (
            <li>
              <a href={link.href} target="_blank" rel="noopener noreferrer" aria-label={link.label} title={link.label}>
                <iconify-icon icon={link.icon} aria-hidden="true"></iconify-icon>
              </a>
            </li>
          ))
        }
      </ul>
    </aside>
  </section>

  <section class="split-layout reveal-in">
    <section class="block" aria-labelledby="quick-paths-heading">
      <div class="section-head">
        <h2 id="quick-paths-heading">Quick Paths</h2>
        <p>Choose the route that best matches why you are here: fit, proof of work, or technical writing.</p>
      </div>

      <div class="pathway-list">
        {
          homeAnchorCards.map((card, index) => (
            <article class="pathway-card" id={card.id}>
              <span class="pathway-index">{String(index + 1).padStart(2, '0')}</span>
              <div>
                <h3>{card.title}</h3>
                <p>{card.description}</p>
                <a href={card.linkHref} class="inline-link">{card.linkLabel}</a>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <aside class="block" aria-labelledby="training-heading">
      <div class="section-head">
        <h2 id="training-heading">Academic Background</h2>
        <p>Formal training across biotechnology, bioinformatics, and quantitative analysis.</p>
      </div>

      <ol class="timeline">
        {
          educationTimeline.map((item) => (
            <li>
              <article class="timeline-card">
                <header>
                  <h3>{item.degree}</h3>
                  <span>{item.years}</span>
                </header>
                <p class="timeline-meta">{item.institution}</p>
                <p>{item.focus}</p>
              </article>
            </li>
          ))
        }
      </ol>
    </aside>
  </section>

  <section class="block domain-panel reveal-in" aria-labelledby="domains-heading">
    <div class="section-head">
      <p class="section-kicker">Domains</p>
      <h2 id="domains-heading">Research Domains</h2>
      <p>Recurring themes across publications, projects, and ongoing work.</p>
    </div>
    <ul class="chip-list">
      {interestTags.map((tag) => <li>{tag}</li>)}
    </ul>
  </section>
</BaseLayout>
