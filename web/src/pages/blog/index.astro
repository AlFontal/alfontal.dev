---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { blogPosts, notebookPreviewImages } from '../../data/content';
import BaseLayout from '../../layouts/BaseLayout.astro';

type BlogListingItem = {
  title: string;
  description: string;
  date: string;
  categories: string[];
  image: ImageMetadata;
  href: string;
  origin: 'manual' | 'notebook';
};

const fallbackPreviewImage = blogPosts[0].image;

const notebookPosts: BlogListingItem[] = (await getCollection('notebooks')).map((entry) => ({
  title: entry.data.title,
  description: entry.data.description,
  date: entry.data.date.toISOString().slice(0, 10),
  categories: entry.data.categories,
  image: notebookPreviewImages[entry.data.image] ?? fallbackPreviewImage,
  href: entry.data.routePath,
  origin: 'notebook',
}));

const manualPosts: BlogListingItem[] = blogPosts.map((post) => ({
  title: post.title,
  description: post.description,
  date: post.date,
  categories: post.categories,
  image: post.image,
  href: post.href,
  origin: 'manual',
}));

const sortedPosts = [...manualPosts, ...notebookPosts].sort((a, b) => (a.date < b.date ? 1 : -1));
const [featuredPost, ...remainingPosts] = sortedPosts;
---

<BaseLayout title="Blog" description="Research notes, coding experiments, and long-form technical posts.">
  <section class="page-intro page-intro--split reveal-in">
    <div class="section-head">
      <p class="section-kicker">Notebook essays / technical notes</p>
      <h1>Blog</h1>
      <p>Published notes where notebook work becomes a readable article with context, figures, and code-aware structure.</p>
    </div>

    <div class="page-intro-stats" aria-label="Blog overview">
      <article>
        <span>{sortedPosts.length}</span>
        <p>published pieces</p>
      </article>
      <article>
        <span>{notebookPosts.length}</span>
        <p>rendered from notebooks</p>
      </article>
      <article>
        <span>{manualPosts.length}</span>
        <p>written directly in Astro</p>
      </article>
    </div>
  </section>

  {featuredPost && (
    <section class="feature-story reveal-in" aria-labelledby="featured-post-heading">
      <div class="feature-story-media">
        <Image
          src={featuredPost.image}
          alt={featuredPost.title}
          width={1200}
          height={630}
          loading="eager"
          fetchpriority="high"
        />
      </div>

      <article class="feature-story-body">
        <p class="section-kicker">Latest entry</p>
        <p class="meta-row">
          <span>{featuredPost.date}</span>
          <span>{featuredPost.origin === 'notebook' ? 'Notebook render' : 'Astro article'}</span>
        </p>
        <h2 id="featured-post-heading">{featuredPost.title}</h2>
        <p class="feature-story-copy">{featuredPost.description}</p>
        <ul class="chip-list compact">
          {featuredPost.categories.map((category) => <li>{category}</li>)}
        </ul>
        <a href={featuredPost.href} class="cta-link is-primary">
          Read {featuredPost.origin === 'notebook' ? 'notebook essay' : 'article'}
        </a>
      </article>
    </section>
  )}

  <section class="editorial-feed reveal-in" aria-label="All blog posts">
    {
      remainingPosts.map((post) => (
        <article class="editorial-entry">
          <div class="editorial-entry-meta">
            <p class="section-kicker">{post.origin === 'notebook' ? 'Notebook render' : 'Astro article'}</p>
            <span>{post.date}</span>
          </div>

          <div class="editorial-entry-body">
            <h2>{post.title}</h2>
            <p>{post.description}</p>
          </div>

          <ul class="chip-list compact">
            {post.categories.map((category) => <li>{category}</li>)}
          </ul>

          <a href={post.href} class="inline-link">
            Read {post.title}
          </a>
        </article>
      ))
    }
  </section>
</BaseLayout>
