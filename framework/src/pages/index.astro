---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  homeAnchorCards,
  homeHero,
  interestTags,
  overviewPanels,
  socialLinks,
  siteMeta,
} from '../data/content';
import portraitImage from '../assets/media/alejandro_hike_profile.jpg';

const profileSocialLinks = socialLinks.filter((link) => link.label !== 'Email');
---

<BaseLayout>
  <section class="hero-grid reveal-in">
    <article class="hero-card hero-stack">
      <div class="hero-title-row">
        <h1>{homeHero.name}</h1>
        <span class="status-dot">{homeHero.credential}</span>
      </div>

      <p class="hero-note">{homeHero.availability}</p>
      <p class="hero-intro">
        {homeHero.tagline}
      </p>

      <div class="fact-grid" aria-label="Core focus areas">
        {
          homeHero.cards.map((card) => (
            <article class="fact-card">
              <h2>{card.title}</h2>
              <p>{card.subtitle}</p>
            </article>
          ))
        }
      </div>
    </article>

    <aside class="portrait-panel">
      <Image
        src={portraitImage}
        alt="Alejandro Fontal hiking in front of a mountain"
        width={720}
        height={720}
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
      <p>
        Contact: <a href={`mailto:${siteMeta.email}`}>{siteMeta.email}</a>
      </p>
      <ul class="portrait-socials" aria-label="Social links">
        {
          profileSocialLinks.map((link) => (
            <li>
              <a href={link.href} target="_blank" rel="noopener noreferrer" aria-label={link.label}>
                <iconify-icon icon={link.icon}></iconify-icon>
              </a>
            </li>
          ))
        }
      </ul>
    </aside>
  </section>

  <section class="block reveal-in" aria-labelledby="quick-paths-heading">
    <div class="section-head">
      <h2 id="quick-paths-heading">Quick Paths</h2>
      <p>Jump straight to hiring, selected work, or the blog.</p>
    </div>

    <div class="anchor-grid">
      {
        homeAnchorCards.map((card) => (
          <article class="anchor-card" id={card.id}>
            <h3>{card.title}</h3>
            <p>{card.description}</p>
            <a href={card.linkHref} class="inline-link">{card.linkLabel}</a>
          </article>
        ))
      }
    </div>
  </section>

  <section class="block reveal-in" aria-labelledby="overview-heading">
    <div class="section-head">
      <h2 id="overview-heading">Role Overview</h2>
      <p>Two snapshots that summarize current work and scientific background.</p>
    </div>

    <div class="pill-row" role="tablist" aria-label="Profile tabs">
      {
        overviewPanels.map((panel, index) => (
          <button
            type="button"
            class={`pill-toggle ${index === 0 ? 'is-active' : ''}`}
            role="tab"
            aria-selected={index === 0 ? 'true' : 'false'}
            aria-controls={`panel-${panel.id}`}
            id={`tab-${panel.id}`}
          >
            {panel.title}
          </button>
        ))
      }
    </div>

    <div class="overview-panels">
      {
        overviewPanels.map((panel, index) => (
          <section
            class="overview-panel"
            id={`panel-${panel.id}`}
            role="tabpanel"
            aria-labelledby={`tab-${panel.id}`}
            hidden={index !== 0}
          >
            {panel.body.map((paragraph) => <p>{paragraph}</p>)}
          </section>
        ))
      }
    </div>
  </section>


  <section class="block reveal-in" aria-labelledby="domains-heading">
    <div class="section-head">
      <h2 id="domains-heading">Research Domains</h2>
      <p>Areas I work on most frequently.</p>
    </div>
    <ul class="chip-list">
      {interestTags.map((tag) => <li>{tag}</li>)}
    </ul>
  </section>

  <script is:inline>
    (() => {
      const overview = document.querySelector('[aria-labelledby=\"overview-heading\"]');
      if (!overview) return;

      const tabs = [...overview.querySelectorAll('.pill-toggle')];
      const panels = [...overview.querySelectorAll('.overview-panel')];
      if (!tabs.length || !panels.length) return;

      const activate = (tab) => {
        const panelId = tab.getAttribute('aria-controls');
        tabs.forEach((item) => {
          const active = item === tab;
          item.classList.toggle('is-active', active);
          item.setAttribute('aria-selected', active ? 'true' : 'false');
        });
        panels.forEach((panel) => {
          panel.hidden = panel.id !== panelId;
        });
      };

      tabs.forEach((tab) => {
        tab.addEventListener('click', () => activate(tab));
        tab.addEventListener('keydown', (event) => {
          const index = tabs.indexOf(tab);
          if (index === -1) return;

          if (event.key === 'ArrowRight' || event.key === 'ArrowDown') {
            event.preventDefault();
            const next = tabs[(index + 1) % tabs.length];
            next.focus();
            activate(next);
          }

          if (event.key === 'ArrowLeft' || event.key === 'ArrowUp') {
            event.preventDefault();
            const prev = tabs[(index - 1 + tabs.length) % tabs.length];
            prev.focus();
            activate(prev);
          }
        });
      });
    })();
  </script>
</BaseLayout>
