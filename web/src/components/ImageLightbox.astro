<dialog class="image-lightbox" data-image-lightbox aria-label="Expanded article image">
  <button type="button" class="image-lightbox-close" data-image-lightbox-close aria-label="Close image viewer">
    <iconify-icon icon="fa6-solid:xmark" aria-hidden="true"></iconify-icon>
  </button>

  <figure class="image-lightbox-frame">
    <img data-image-lightbox-image alt="" />
    <figcaption data-image-lightbox-caption hidden></figcaption>
  </figure>
</dialog>

<script is:inline>
  (() => {
    const dialog = document.querySelector('[data-image-lightbox]');
    const lightboxImage = dialog?.querySelector('[data-image-lightbox-image]');
    const lightboxCaption = dialog?.querySelector('[data-image-lightbox-caption]');
    const closeButton = dialog?.querySelector('[data-image-lightbox-close]');
    const imageSelector = '[data-lightbox-root] img:not([data-lightbox-ignore])';

    if (!(dialog instanceof HTMLDialogElement) || !(lightboxImage instanceof HTMLImageElement) || !(lightboxCaption instanceof HTMLElement)) {
      return;
    }

    let activeImage = null;

    const getCaption = (image) => {
      const figure = image.closest('figure');
      const caption = figure?.querySelector('figcaption');
      const captionText = caption?.textContent?.trim();

      if (captionText) return captionText;

      const altText = image.getAttribute('alt')?.trim();
      return altText || '';
    };

    const openLightbox = (image) => {
      activeImage = image;
      lightboxImage.src = image.currentSrc || image.src;
      lightboxImage.srcset = image.srcset || '';
      lightboxImage.sizes = image.srcset ? '100vw' : '';
      lightboxImage.alt = image.alt || '';

      const caption = getCaption(image);
      lightboxCaption.textContent = caption;
      lightboxCaption.hidden = !caption;

      dialog.showModal();
      document.body.classList.add('lightbox-open');
    };

    const closeLightbox = () => {
      dialog.close();
    };

    const syncImages = () => {
      document.querySelectorAll(imageSelector).forEach((image) => {
        if (!(image instanceof HTMLImageElement) || image.dataset.lightboxReady === 'true') return;
        if (image.closest('a[href]')) return;

        image.dataset.lightboxReady = 'true';
        image.classList.add('is-lightboxable');
        image.tabIndex = 0;
        image.setAttribute('role', 'button');
        image.setAttribute('aria-haspopup', 'dialog');
        image.setAttribute('aria-label', `Expand image${image.alt ? `: ${image.alt}` : ''}`);

        image.addEventListener('click', () => openLightbox(image));
        image.addEventListener('keydown', (event) => {
          if (event.key !== 'Enter' && event.key !== ' ') return;
          event.preventDefault();
          openLightbox(image);
        });
      });
    };

    syncImages();

    closeButton?.addEventListener('click', closeLightbox);

    dialog.addEventListener('click', (event) => {
      if (event.target === dialog) {
        closeLightbox();
      }
    });

    dialog.addEventListener('close', () => {
      document.body.classList.remove('lightbox-open');
      lightboxImage.removeAttribute('src');
      lightboxImage.removeAttribute('srcset');
      lightboxImage.removeAttribute('sizes');

      if (activeImage instanceof HTMLElement) {
        activeImage.focus();
      }

      activeImage = null;
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && dialog.open) {
        closeLightbox();
      }
    });
  })();
</script>
