---
import BaseLayout from '../layouts/BaseLayout.astro';
import { cvEducation, cvExperience, cvHeader, cvLanguages, cvSkills, cvTagOrder } from '../data/cv';

const allTags = Array.from(new Set(cvExperience.flatMap((item) => item.tags)));
allTags.sort((a, b) => {
  const ai = cvTagOrder.indexOf(a);
  const bi = cvTagOrder.indexOf(b);
  if (ai === -1 && bi === -1) return a.localeCompare(b);
  if (ai === -1) return 1;
  if (bi === -1) return -1;
  return ai - bi;
});
---

<BaseLayout title="CV" description="Experience, skills, and education for Alejandro Fontal.">
  <section class="cv-hero reveal-in">
    <div>
      <p class="article-kicker">Curriculum Vitae</p>
      <h1>{cvHeader.name}</h1>
      <p class="cv-title">{cvHeader.title}</p>
      <p class="cv-meta">
        <iconify-icon icon="mdi:map-marker" aria-hidden="true"></iconify-icon>
        <span>{cvHeader.location}</span>
      </p>
      <div class="cv-meta-links">
        <a href={`tel:${cvHeader.phone.replace(/\s+/g, '')}`} class="cv-meta-pill">
          <iconify-icon icon="fa6-solid:phone" aria-hidden="true"></iconify-icon>
          <span>{cvHeader.phone}</span>
        </a>
        <a class="cv-download" href="/assets/cv/Alejandro_Fontal_CV-4.pdf" target="_blank" rel="noopener noreferrer">
          <iconify-icon icon="fa6-solid:file-pdf" aria-hidden="true"></iconify-icon>
          Open Original PDF
        </a>
      </div>
    </div>
    <div class="cv-actions">
      <ul class="cv-contact-list">
        <li>
          <a href={`mailto:${cvHeader.email}`} class="cv-contact-pill is-email">
            <iconify-icon icon="fa6-solid:envelope" aria-hidden="true"></iconify-icon>
            <span>Email: {cvHeader.email}</span>
          </a>
        </li>
        <li>
          <a href={cvHeader.linkedin} target="_blank" rel="noopener noreferrer" class="cv-contact-pill is-linkedin">
            <iconify-icon icon="fa6-brands:linkedin" aria-hidden="true"></iconify-icon>
            <span>LinkedIn: {cvHeader.linkedinHandle}</span>
          </a>
        </li>
        <li>
          <a href={cvHeader.github} target="_blank" rel="noopener noreferrer" class="cv-contact-pill is-github">
            <iconify-icon icon="fa6-brands:github" aria-hidden="true"></iconify-icon>
            <span>GitHub: {cvHeader.githubHandle}</span>
          </a>
        </li>
        <li>
          <a href={cvHeader.gitlab} target="_blank" rel="noopener noreferrer" class="cv-contact-pill is-gitlab">
            <iconify-icon icon="fa6-brands:gitlab" aria-hidden="true"></iconify-icon>
            <span>GitLab: {cvHeader.gitlabHandle}</span>
          </a>
        </li>
        <li>
          <a href={cvHeader.orcid} target="_blank" rel="noopener noreferrer" class="cv-contact-pill is-orcid">
            <iconify-icon icon="fa6-brands:orcid" aria-hidden="true"></iconify-icon>
            <span>ORCID: {cvHeader.orcidId}</span>
          </a>
        </li>
      </ul>
    </div>
  </section>

  <section class="block reveal-in" aria-labelledby="cv-skills-heading">
    <div class="section-head">
      <h2 id="cv-skills-heading">Development Skills</h2>
      <p>Core software and technical capabilities used in research and production workflows.</p>
    </div>
    <div class="cv-skill-grid">
      {
        cvSkills.map((skill) => (
          <article class="cv-skill-card">
            <h3>
              <iconify-icon icon={skill.icon} aria-hidden="true"></iconify-icon>
              <span>{skill.title}</span>
            </h3>
            <p>{skill.details}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="block reveal-in" aria-labelledby="cv-experience-heading">
    <div class="section-head">
      <h2 id="cv-experience-heading">Working Experience</h2>
      <p>Use filters to focus on specific domains, tools, or methods.</p>
    </div>

    <div class="cv-controls">
      <label class="cv-search">
        <span>Search</span>
        <input type="search" placeholder="Filter roles, organizations, highlights..." data-cv-search />
      </label>

      <div class="cv-filter-group" data-cv-filters>
        {
          allTags.map((tag) => (
            <button type="button" class="cv-filter-chip" data-filter={tag} aria-pressed="false">
              {tag}
            </button>
          ))
        }
        <button type="button" class="cv-filter-chip is-clear" data-filter-clear>Clear filters</button>
      </div>

      <p class="cv-result" data-cv-result>{cvExperience.length} roles visible</p>
    </div>

    <div class="cv-experience-list" data-cv-list>
      {
        cvExperience.map((item) => (
          <article
            class="cv-experience-card"
            data-cv-item
            data-tags={item.tags.join('|').toLowerCase()}
            data-search={[item.role, item.organization, item.location, item.summary ?? '', ...item.highlights, ...item.tags]
              .join(' ')
              .toLowerCase()}
          >
            <header>
              <div>
                <h3>{item.role}</h3>
                <p class="cv-org">{item.organization}</p>
              </div>
              <div class="cv-timeplace">
                <span>{item.date}</span>
                <span class="cv-location">
                  <iconify-icon icon="mdi:map-marker" aria-hidden="true"></iconify-icon>
                  <span>{item.location}</span>
                </span>
              </div>
            </header>
            {item.summary && <p class="cv-summary">{item.summary}</p>}
            <ul>
              {item.highlights.map((point) => <li>{point}</li>)}
            </ul>
            <ul class="chip-list compact cv-tag-list">
              {item.tags.map((tag) => <li>{tag}</li>)}
            </ul>
          </article>
        ))
      }
    </div>
  </section>

  <section class="block reveal-in" aria-labelledby="cv-details-heading">
    <div class="section-head">
      <h2 id="cv-details-heading">Education & Languages</h2>
      <p>Academic background and language profile.</p>
    </div>

    <div class="cv-detail-grid">
      <section class="cv-detail-panel cv-education-panel">
        <div class="cv-education-list">
          {
            cvEducation.map((item) => (
              <article class="cv-education-card">
                <header>
                  <h3>{item.degree}</h3>
                  <div class="cv-timeplace">
                    <span>{item.date}</span>
                    <span class="cv-location">
                      <iconify-icon icon="mdi:map-marker" aria-hidden="true"></iconify-icon>
                      <span>{item.location}</span>
                    </span>
                  </div>
                </header>
                <p class="cv-org">{item.institution}</p>
                <ul>
                  {item.details.map((detail) => <li>{detail}</li>)}
                </ul>
              </article>
            ))
          }
        </div>
      </section>

      <aside class="cv-detail-panel cv-languages-panel">
        <div class="cv-languages-list">
          {
            cvLanguages.map((item) => (
              <article class="cv-language-card">
                <h3>{item.name}</h3>
                <p>{item.level}</p>
                {item.notes && <span>{item.notes}</span>}
              </article>
            ))
          }
        </div>
      </aside>
    </div>
  </section>

  <script is:inline>
    (() => {
      const root = document;
      const input = root.querySelector('[data-cv-search]');
      const result = root.querySelector('[data-cv-result]');
      const cards = [...root.querySelectorAll('[data-cv-item]')];
      const filterButtons = [...root.querySelectorAll('[data-filter]')];
      const clearButton = root.querySelector('[data-filter-clear]');
      const activeFilters = new Set();

      if (!input || !result || !cards.length) return;

      const update = () => {
        const query = String(input.value || '').trim().toLowerCase();
        let visible = 0;

        cards.forEach((card) => {
          const searchHaystack = String(card.getAttribute('data-search') || '');
          const tags = String(card.getAttribute('data-tags') || '');
          const matchesQuery = !query || searchHaystack.includes(query);
          const matchesFilter = !activeFilters.size || [...activeFilters].every((tag) => tags.includes(tag));
          const show = matchesQuery && matchesFilter;
          card.hidden = !show;
          if (show) visible += 1;
        });

        result.textContent = `${visible} role${visible === 1 ? '' : 's'} visible`;
      };

      filterButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const value = String(button.getAttribute('data-filter') || '').toLowerCase();
          if (!value) return;

          if (activeFilters.has(value)) {
            activeFilters.delete(value);
            button.setAttribute('aria-pressed', 'false');
            button.classList.remove('is-active');
          } else {
            activeFilters.add(value);
            button.setAttribute('aria-pressed', 'true');
            button.classList.add('is-active');
          }

          update();
        });
      });

      clearButton?.addEventListener('click', () => {
        activeFilters.clear();
        filterButtons.forEach((button) => {
          button.setAttribute('aria-pressed', 'false');
          button.classList.remove('is-active');
        });
        input.value = '';
        update();
      });

      input.addEventListener('input', update);
      update();
    })();
  </script>
</BaseLayout>
