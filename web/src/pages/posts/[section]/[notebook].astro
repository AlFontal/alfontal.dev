---
import { readFile } from 'node:fs/promises';
import path from 'node:path';
import { getCollection, getEntry, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import GiscusComments from '../../../components/GiscusComments.astro';
import ImageLightbox from '../../../components/ImageLightbox.astro';
import QuartoEnhancements from '../../../components/QuartoEnhancements.astro';

export async function getStaticPaths() {
  const notebooks = await getCollection('notebooks');

  return notebooks.map((entry) => ({
    params: {
      section: entry.data.section,
      notebook: entry.data.notebook,
    },
    props: { entryId: entry.id },
  }));
}

type Props = {
  entryId: CollectionEntry<'notebooks'>['id'];
};

const { entryId } = Astro.props;
const entry = await getEntry('notebooks', entryId);
if (!entry) {
  throw new Error(`Notebook entry not found for id '${entryId}'`);
}

const readGeneratedFile = async (relativePath?: string) => {
  if (!relativePath) {
    return '';
  }

  try {
    return await readFile(path.join(process.cwd(), relativePath), 'utf8');
  } catch (error) {
    if (error instanceof Error && 'code' in error && error.code === 'ENOENT') {
      return '';
    }
    throw error;
  }
};

const quartoHtml = await readGeneratedFile(entry.data.quartoHtmlPath);
const quartoStyles = await readGeneratedFile(entry.data.quartoStylesPath);
if (!quartoHtml) {
  throw new Error(`Missing generated Quarto HTML for '${entry.data.routePath}'`);
}

const quartoAssetBase = `/assets/notebooks/${entry.data.section}/${entry.data.notebook}/${entry.data.notebook}_files`;
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  {quartoStyles && <Fragment slot="head" set:html={quartoStyles} />}
  <section class="quarto-post-layout">
    <article class:list={['article', 'notebook-article', 'quarto-article', 'reveal-in']} data-lightbox-root>
      <div class="notebook-content quarto-document" set:html={quartoHtml} />
    </article>

    <div class="quarto-comments-shell">
      <GiscusComments />
    </div>
  </section>

  <QuartoEnhancements assetBasePath={quartoAssetBase} />
  <ImageLightbox />
</BaseLayout>
