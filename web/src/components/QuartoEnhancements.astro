---
interface Props {
  assetBasePath: string;
}

const { assetBasePath } = Astro.props;
---

<script is:inline define:vars={{ assetBasePath }}>
  (() => {
    const enhanceAnchors = () => {
      document.querySelectorAll('.quarto-document .anchored').forEach((heading) => {
        if (!(heading instanceof HTMLElement)) return;
        if (heading.querySelector('.header-anchor')) return;

        const anchorId = heading.dataset.anchorId || heading.id;
        if (!anchorId) return;

        if (!heading.id) {
          heading.id = anchorId;
        }

        const anchor = document.createElement('a');
        anchor.className = 'header-anchor';
        anchor.href = `#${anchorId}`;
        anchor.setAttribute('aria-label', 'Link to this section');
        anchor.textContent = '#';

        heading.append(' ', anchor);

        heading.addEventListener('mouseleave', () => heading.classList.remove('reveal-anchor'));
        anchor.addEventListener('focus', () => heading.classList.add('reveal-anchor'));
        anchor.addEventListener('blur', () => heading.classList.remove('reveal-anchor'));
      });
    };

    const enhanceTabsets = () => {
      const tabsets = Array.from(document.querySelectorAll('.quarto-document .panel-tabset'));
      if (!tabsets.length) return;

      const storageKey = 'quarto-persistent-tabsets-data';

      const readSettings = () => {
        try {
          return JSON.parse(localStorage.getItem(storageKey) || '{}');
        } catch {
          return {};
        }
      };

      const writeSettings = (nextSettings) => {
        localStorage.setItem(storageKey, JSON.stringify(nextSettings));
      };

      const activateTab = (tabset, tab) => {
        if (!(tab instanceof HTMLElement)) return;

        const tabs = Array.from(tabset.querySelectorAll('[data-bs-toggle="tab"], [role="tab"]'));
        tabs.forEach((candidate) => {
          if (!(candidate instanceof HTMLElement)) return;
          const isActive = candidate === tab;
          candidate.classList.toggle('active', isActive);
          candidate.setAttribute('aria-selected', isActive ? 'true' : 'false');
          candidate.tabIndex = isActive ? 0 : -1;

          const targetId =
            candidate.getAttribute('data-bs-target')?.replace(/^#/, '') ||
            candidate.getAttribute('href')?.split('#')[1] ||
            candidate.getAttribute('aria-controls');

          if (!targetId) return;

          const panel = document.getElementById(targetId);
          if (!(panel instanceof HTMLElement)) return;
          panel.classList.toggle('active', isActive);
          panel.classList.toggle('show', isActive);
        });
      };

      const syncGroupedTabs = (groupName, labelText) => {
        document.querySelectorAll(`.quarto-document .panel-tabset[data-group="${groupName}"]`).forEach((tabset) => {
          const matchingTab = Array.from(tabset.querySelectorAll('[data-bs-toggle="tab"], [role="tab"]')).find((tab) => {
            return tab instanceof HTMLElement && tab.textContent?.trim() === labelText;
          });

          if (matchingTab instanceof HTMLElement) {
            activateTab(tabset, matchingTab);
          }
        });
      };

      tabsets.forEach((tabset) => {
        const tabs = Array.from(tabset.querySelectorAll('[data-bs-toggle="tab"], [role="tab"]'));
        if (!tabs.length) return;

        tabs.forEach((tab, index) => {
          if (!(tab instanceof HTMLElement)) return;

          tab.addEventListener('click', (event) => {
            event.preventDefault();
            activateTab(tabset, tab);

            const groupName = tabset.getAttribute('data-group');
            const labelText = tab.textContent?.trim();
            if (groupName && labelText) {
              const nextSettings = readSettings();
              nextSettings[groupName] = labelText;
              writeSettings(nextSettings);
              syncGroupedTabs(groupName, labelText);
            }
          });

          if (!tab.classList.contains('active') && index === 0) {
            tab.tabIndex = -1;
          }
        });

        const groupName = tabset.getAttribute('data-group');
        const savedLabel = groupName ? readSettings()[groupName] : null;
        const savedTab = savedLabel
          ? tabs.find((tab) => tab instanceof HTMLElement && tab.textContent?.trim() === savedLabel)
          : null;
        const defaultTab = savedTab || tabs.find((tab) => tab instanceof HTMLElement && tab.classList.contains('active')) || tabs[0];

        if (defaultTab instanceof HTMLElement) {
          activateTab(tabset, defaultTab);
        }
      });
    };

    const enhanceToc = () => {
      const tocEl = document.querySelector('.quarto-document nav.toc-active[role="doc-toc"]');
      const marginSidebarEl = document.querySelector('.quarto-document #quarto-margin-sidebar');
      if (!(tocEl instanceof HTMLElement)) return;

      const tocLinks = Array.from(tocEl.querySelectorAll('a[data-scroll-target]')).filter(
        (link) => link instanceof HTMLAnchorElement,
      );
      if (!tocLinks.length) return;

      const sections = tocLinks.map((link) => {
        const target = link.getAttribute('data-scroll-target');
        if (!target) return null;
        if (target.startsWith('#')) {
          return document.getElementById(decodeURI(target.slice(1)));
        }
        const resolved = document.querySelector(decodeURI(target));
        return resolved instanceof HTMLElement ? resolved : null;
      });

      const prevSiblingIsActiveLink = (el) => {
        const sibling = el.previousElementSibling;
        return sibling instanceof HTMLAnchorElement && sibling.classList.contains('active');
      };

      const removeAllActive = () => {
        tocLinks.forEach((link) => link.classList.remove('active'));
      };

      let currentActive = 0;
      let didInit = false;
      const sectionMargin = Math.max(
        160,
        parseInt(getComputedStyle(document.documentElement).getPropertyValue('--header-offset'), 10) || 0,
      );

      const updateActiveLink = () => {
        let sectionIndex = -1;

        if (window.innerHeight + window.pageYOffset >= document.body.offsetHeight) {
          sectionIndex = 0;
        } else {
          sectionIndex = [...sections].reverse().findIndex((section) => {
            return section instanceof HTMLElement && window.pageYOffset >= section.offsetTop - sectionMargin;
          });
        }

        if (sectionIndex > -1) {
          const nextActive = sections.length - sectionIndex - 1;
          if (nextActive !== currentActive || !didInit) {
            removeAllActive();
            currentActive = nextActive;
            tocLinks[currentActive]?.classList.add('active');
            didInit = true;
          }
        }
      };

      const tocOpenDepthValue = Number(tocEl.getAttribute('data-toc-expanded') || '1');
      const tocOpenDepth = Number.isNaN(tocOpenDepthValue) ? 1 : tocOpenDepthValue;

      const walkToc = (el, depth) => {
        let nextDepth = depth;
        if (el.tagName === 'UL') {
          nextDepth += 1;
        }

        const isActiveNode = el instanceof HTMLAnchorElement && el.classList.contains('active');
        let hasActiveChild = false;

        Array.from(el.children).forEach((child) => {
          hasActiveChild = walkToc(child, nextDepth) || hasActiveChild;
        });

        if (el.tagName === 'UL') {
          if (tocOpenDepth === -1 && nextDepth > 1) {
            el.classList.add('collapse');
          } else if (nextDepth <= tocOpenDepth || hasActiveChild || prevSiblingIsActiveLink(el)) {
            el.classList.remove('collapse');
          } else {
            el.classList.add('collapse');
          }
        }

        return hasActiveChild || isActiveNode;
      };

      if (!(marginSidebarEl instanceof HTMLElement)) {
        updateActiveLink();
        walkToc(tocEl, 0);
        return;
      }

      let toggleContainer = null;
      let closeToggle = () => {};

      const positionToggle = () => {
        if (!(toggleContainer instanceof HTMLElement)) return;
        const sidebarRect = marginSidebarEl.getBoundingClientRect();
        const clampedLeft = Math.max(12, Math.min(sidebarRect.left, window.innerWidth - sidebarRect.width - 12));
        toggleContainer.style.left = `${clampedLeft}px`;
        toggleContainer.style.top = `${Math.max(sidebarRect.top, 12)}px`;
        toggleContainer.style.width = `${sidebarRect.width}px`;
      };

      const convertToMenu = () => {
        if (toggleContainer instanceof HTMLElement) {
          positionToggle();
          return;
        }

        Array.from(marginSidebarEl.children).forEach((child) => {
          if (!(child instanceof HTMLElement)) return;
          child.style.opacity = '0';
          child.style.overflow = 'hidden';
          child.style.pointerEvents = 'none';
        });

        const titleText = tocEl.querySelector('#toc-title')?.textContent?.trim() || 'Contents';

        toggleContainer = document.createElement('div');
        toggleContainer.id = 'quarto-toc-toggle';
        toggleContainer.className = 'quarto-sidebar-toggle zindex-over-content';
        toggleContainer.style.position = 'fixed';

        const toggleTitle = document.createElement('button');
        toggleTitle.type = 'button';
        toggleTitle.className = 'quarto-sidebar-toggle-title zindex-over-content';
        toggleTitle.setAttribute('aria-expanded', 'false');
        toggleTitle.innerHTML = `<span>${titleText}</span><span class="quarto-sidebar-toggle-icon" aria-hidden="true"></span>`;

        const toggleContents = document.createElement('div');
        toggleContents.className = 'quarto-sidebar-toggle-contents zindex-over-content';
        toggleContents.style.height = '0px';

        Array.from(tocEl.children).forEach((child) => {
          if (!(child instanceof HTMLElement) || child.id === 'toc-title') return;
          toggleContents.append(child.cloneNode(true));
        });

        let isExpanded = false;
        closeToggle = () => {
          if (!toggleContainer || !isExpanded) return;
          toggleContainer.classList.remove('expanded');
          toggleTitle.setAttribute('aria-expanded', 'false');
          toggleContents.style.height = '0px';
          isExpanded = false;
        };

        toggleTitle.addEventListener('click', () => {
          if (!toggleContainer) return;
          if (isExpanded) {
            closeToggle();
            return;
          }

          toggleContainer.classList.add('expanded');
          toggleTitle.setAttribute('aria-expanded', 'true');
          toggleContents.style.height = `${toggleContents.scrollHeight}px`;
          isExpanded = true;
        });

        toggleContents.addEventListener('click', (event) => {
          const target = event.target;
          if (target instanceof HTMLAnchorElement) {
            closeToggle();
          }
        });

        toggleContainer.append(toggleTitle, toggleContents);
        marginSidebarEl.parentElement?.prepend(toggleContainer);
        positionToggle();
      };

      const convertToSidebar = () => {
        closeToggle();
        toggleContainer?.remove();
        toggleContainer = null;

        Array.from(marginSidebarEl.children).forEach((child) => {
          if (!(child instanceof HTMLElement)) return;
          child.style.opacity = '1';
          child.style.overflow = '';
          child.style.pointerEvents = '';
        });
      };

      const overlapPadding = 10;
      const conflictingSelector =
        '.quarto-document [class^="column-"], .quarto-document [class*=" column-"], .quarto-document aside, .quarto-document [class*="margin-caption"], .quarto-document [class*=" margin-caption"], .quarto-document [class*="margin-ref"], .quarto-document [class*=" margin-ref"]';

      const isRightConflict = (el) => {
        if (!(el instanceof HTMLElement)) return false;
        if (el === marginSidebarEl || marginSidebarEl.contains(el)) return false;
        if (el.tagName === 'ASIDE') return true;
        if (el.classList.contains('margin-caption')) return true;

        return Array.from(el.classList).some((className) => {
          return (
            className !== 'column-body' &&
            !className.endsWith('container') &&
            className.startsWith('column-') &&
            !className.endsWith('left')
          );
        });
      };

      const rightConflictEls = Array.from(document.querySelectorAll(conflictingSelector)).filter(isRightConflict);

      const hasVisibleOverlap = () => {
        const activeTocBox = toggleContainer instanceof HTMLElement ? toggleContainer : tocEl;
        if (!(activeTocBox instanceof HTMLElement)) return false;

        const tocRect = activeTocBox.getBoundingClientRect();
        const hasVisibleToc = tocRect.bottom > 0 && tocRect.top < window.innerHeight;
        if (!hasVisibleToc) return false;

        return rightConflictEls.some((el) => {
          if (!(el instanceof HTMLElement)) return false;
          const rect = el.getBoundingClientRect();
          if (rect.bottom <= 0 || rect.top >= window.innerHeight) return false;

          const verticalOverlap = tocRect.top <= rect.bottom + overlapPadding && tocRect.bottom >= rect.top - overlapPadding;
          const horizontalOverlap = tocRect.left <= rect.right + overlapPadding && tocRect.right >= rect.left - overlapPadding;
          return verticalOverlap && horizontalOverlap;
        });
      };

      const syncToc = () => {
        updateActiveLink();
        walkToc(tocEl, 0);

        if (hasVisibleOverlap()) {
          convertToMenu();
        } else {
          convertToSidebar();
        }
      };

      document.addEventListener(
        'scroll',
        () => {
          syncToc();
          closeToggle();
        },
        { passive: true },
      );

      window.addEventListener('resize', syncToc);
      syncToc();
    };

    const enhanceCitations = () => {
      const citationLinks = Array.from(document.querySelectorAll('.quarto-document a[role="doc-biblioref"]'));
      if (!citationLinks.length) return;

      citationLinks.forEach((link) => {
        if (!(link instanceof HTMLAnchorElement)) return;
        const refId = link.getAttribute('href')?.replace(/^#/, '');
        if (!refId) return;

        const ref = document.getElementById(refId);
        if (!(ref instanceof HTMLElement)) return;

        const tooltip = ref.textContent?.replace(/\s+/g, ' ').trim();
        if (!tooltip) return;

        link.title = tooltip;

        if (typeof window.tippy === 'function') {
          window.tippy(link, {
            content: ref.innerHTML,
            allowHTML: true,
            interactive: true,
            maxWidth: 420,
            placement: 'bottom-start',
            theme: 'quarto-citations',
          });
        }
      });
    };

    const loadNotebookRuntime = () => {
      if (!assetBasePath) return;

      const script = document.createElement('script');
      script.src = `${assetBasePath}/libs/bootstrap/bootstrap.min.js`;
      script.defer = true;
      document.head.appendChild(script);
    };

    const init = () => {
      loadNotebookRuntime();
      window.Quarto?.typesetMath?.(document.querySelector('.quarto-document') || document.body);
      enhanceAnchors();
      enhanceCitations();
      enhanceTabsets();
      enhanceToc();
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init, { once: true });
    } else {
      init();
    }
  })();
</script>
