---
import BaseLayout from '../layouts/BaseLayout.astro';
import { publications, publicationsPage } from '../data/content';

const publicationSortValue = (value?: string, year?: number) => {
  if (value) return new Date(value).getTime();
  return new Date(`${year ?? 0}-01-01`).getTime();
};

const sortedPublications = [...publications].sort((a, b) => {
  const byYear = b.year - a.year;
  if (byYear !== 0) return byYear;

  const byDate = publicationSortValue(b.publishedOn, b.year) - publicationSortValue(a.publishedOn, a.year);
  if (byDate !== 0) return byDate;

  return a.title.localeCompare(b.title);
});
const normalizeAuthors = (authors: string) => authors.replace(/alejandro\s+fontal/gi, 'Alejandro Fontal');
const highlightAuthors = (authors: string) => normalizeAuthors(authors).split(/(Alejandro Fontal)/g);
const publicationGroups = Object.entries(
  sortedPublications.reduce<Record<string, typeof sortedPublications>>((groups, item) => {
    const key = String(item.year);
    groups[key] ??= [];
    groups[key].push(item);
    return groups;
  }, {})
).sort((a, b) => Number(b[0]) - Number(a[0]));
---

<BaseLayout title={publicationsPage.seoTitle} description={publicationsPage.description}>
  <section class="page-intro reveal-in">
    <div class="section-head">
      <p class="section-kicker">{publicationsPage.kicker}</p>
      <h1>{publicationsPage.title}</h1>
      <p>{publicationsPage.intro}</p>
    </div>
  </section>

  <section class="publication-year-grid reveal-in" aria-label="Publication records">
    {
      publicationGroups.map(([year, items]) => (
        <section class="publication-year-group">
          <div class="publication-year-label">
            <span>{year}</span>
          </div>

          <div class="publication-year-list">
            {items.map((item) => (
              <article class="publication-record">
                <header>
                  <p class="section-kicker">{item.publication}</p>
                  <h2>{item.title}</h2>
                </header>
                <p class="publication-authors">
                  {
                    highlightAuthors(item.authors).map((segment) =>
                      segment === 'Alejandro Fontal' ? <strong>{segment}</strong> : segment
                    )
                  }
                </p>
                <ul class="chip-list compact">
                  {item.categories.map((category) => <li>{category}</li>)}
                </ul>
                <div class="link-row">
                  {item.doi && (
                    <a href={item.doi} class="publication-link publication-link--journal" target="_blank" rel="noopener noreferrer">
                      <iconify-icon icon="fa6-solid:link" aria-hidden="true"></iconify-icon>
                      <span>{publicationsPage.links.journal}</span>
                    </a>
                  )}
                  {item.pdf && (
                    <a href={item.pdf} class="publication-link publication-link--pdf" target="_blank" rel="noopener noreferrer">
                      <iconify-icon icon="fa6-solid:file-pdf" aria-hidden="true"></iconify-icon>
                      <span>{publicationsPage.links.pdf}</span>
                    </a>
                  )}
                  {item.code && (
                    <a href={item.code} class="publication-link publication-link--code" target="_blank" rel="noopener noreferrer">
                      <iconify-icon icon={item.code.includes('github.com') ? 'fa6-brands:github' : 'fa6-solid:code'} aria-hidden="true"></iconify-icon>
                      <span>{publicationsPage.links.code}</span>
                    </a>
                  )}
                </div>
              </article>
            ))}
          </div>
        </section>
      ))
    }
  </section>
</BaseLayout>
